{
  "name": "@mcpmarket/mcp-auto-install",
  "version": "0.2.1",
  "description": "MCP server that discovers and installs MCP servers from the official registry",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mai": "./dist/index.js",
    "mcp-auto-install": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CherryHQ/mcpmarket.git",
    "directory": "packages/mcp-auto-install"
  },
  "homepage": "https://github.com/CherryHQ/mcpmarket/tree/main/packages/mcp-auto-install#readme",
  "bugs": {
    "url": "https://github.com/CherryHQ/mcpmarket/issues"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "server",
    "auto-install",
    "registry",
    "ai",
    "llm",
    "claude",
    "cursor",
    "automation"
  ],
  "author": "whatprototype",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^11.1.0",
    "npx-scope-finder": "^2.0.2",
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
